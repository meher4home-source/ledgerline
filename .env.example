# Supabase (Settings -> API in your Supabase project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Twelve Data (free tier: twelvedata.com/pricing -> Sign up -> API key)
TWELVE_DATA_API_KEY=

# Dodo Payments (Dashboard -> Developer -> API Keys, and -> Webhooks)
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_PAYMENTS_PRODUCT_ID=
# "test_mode" while developing, "live_mode" once you're ready to take real payments
DODO_PAYMENTS_ENVIRONMENT=test_mode

# Your deployed app URL (used for redirects). Set this to your real Vercel URL after first deploy.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Length of the free trial in days
NEXT_PUBLIC_TRIAL_DAYS=14
